# ===================================================
# FounderGPT OS - Environment Variables
# ===================================================
# Copy this file to .env.local and fill in your values.
# ===================================================

# --- AI / LLM (Groq) ---
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=

# --- Authentication ---
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# --- App URL ---
NEXT_PUBLIC_APP_URL=

# --- Database (AWS Aurora PostgreSQL) ---
# For local dev with PEM file: add &sslrootcert=./rds-combined-ca-bundle.pem
# For Vercel/AWS deploy: sslmode=require (no PEM needed)
DATABASE_URL=
